TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OWNER_WHATSAPP=whatsapp:+919876543210

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
